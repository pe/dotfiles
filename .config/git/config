[include]
	path = ~/.config/git/local
[core]
	excludesfile = ~/.config/git/ignore_global
	pager= delta
	hooksPath = ~/.config/git/hooks
[fetch]
	prune = true
	pruneTags = true
[interactive]
	diffFilter = delta --color-only
[feature]
	manyFiles = true
[alias]
	ls  = log --format=format:'%C(magenta)%h %C(cyan)%ah %C(green)%an %C(white)%s %C(auto)%D%C(reset)'
	lsa = log --format=format:'%C(magenta)%h %C(cyan)%ah %C(green)%an %C(white)%s %C(auto)%D%C(reset)' --graph --all
	rebaseonly= "!git rebase --interactive $(git merge-base $1 HEAD) #"
	staash = stash --all
[rebase]
	autosquash = true
	updateRefs = true
	autoStash = true
[push]
	useForceIfIncludes = true
	autoSetupRemote = true
	followTags = true
[pull]
	rebase = true
[rerere]
	enabled = true
	autoUpdate = true
[merge]
	tool = intellij
	conflictstyle = zdiff3
[mergetool]
	keepBackup = false
[mergetool "vscode"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
[mergetool "intellij"]
	cmd = open -nWa 'IntelliJ IDEA.app' --args merge $(realpath $LOCAL) $(realpath $REMOTE) $(realpath $BASE) $(realpath $MERGED)
	trustExitCode = true
[diff]
	algorithm = histogram
	tool = intellij
	colorMoved = default
	mnemonicPrefix = true
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[difftool "intellij"]
	cmd = open -nWa 'IntelliJ IDEA.app' --args diff $(realpath "$LOCAL") $(realpath "$REMOTE")
[delta]
	hyperlinks = true
	hyperlinks-file-link-format = "idea://open?file={path}&line={line}"
	file-style = omit
	hunk-header-style = file syntax
	hunk-header-file-style = normal
	hunk-header-decoration-style = omit
	line-numbers = true
	blame-code-style = syntax
	blame-format = "{author:<18} {commit:<6} {timestamp:<15}"
# https://github.com/folke/tokyonight.nvim/tree/main/extras/delta
[delta "tokyonight_night"]
	syntax-theme = "tokyonight_night"
	minus-style = syntax "#4a272f"
	minus-non-emph-style = syntax "#4a272f"
	minus-emph-style = syntax "#713137"
	minus-empty-line-marker-style = syntax "#4a272f"
	line-numbers-minus-style = "#914c54"
	plus-style = syntax "#243e4a"
	plus-non-emph-style = syntax "#243e4a"
	plus-emph-style = syntax "#2c5a66"
	plus-empty-line-marker-style = syntax "#243e4a"
	line-numbers-plus-style = "#449dab"
	line-numbers-zero-style = "#3b4261"
[delta "tokyonight_day"]
	syntax-theme = "tokyonight_day"
	minus-style = syntax "#dababe"
	minus-non-emph-style = syntax "#dababe"
	minus-emph-style = syntax "#d59a9d"
	minus-empty-line-marker-style = syntax "#dababe"
	line-numbers-minus-style = "#c47981"
	plus-style = syntax "#b7ced5"
	plus-non-emph-style = syntax "#b7ced5"
	plus-emph-style = syntax "#95bec7"
	plus-empty-line-marker-style = syntax "#b7ced5"
	line-numbers-plus-style = "#4197a4"
	line-numbers-zero-style = "#a8aecb"
[help]
	autocorrect = prompt
[trim]
	protected = *release/*,*hotfix/*
[submodule]
	recurse = true
[maintenance "gc"]
	schedule = weekly
[tag]
	sort = version:refname
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
